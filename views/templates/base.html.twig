<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app.name }}{% endblock %}</title>
    {% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/app.css">
    {% endblock %}
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">{{ app.name }}</a>
            <ul class="navbar-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; {{ "now"|date("Y") }} {{ app.name }}. All rights reserved.</p>
        </div>
    </footer>

    {% block javascripts %}
    <script src="/assets/js/app.js"></script>
    {% endblock %}
</body>
</html>
